{
  "name": "hermes",
  "version": "0.3.1",
  "private": true,
  "description": "Open-source multi-domain mail server",
  "type": "module",
  "scripts": {
    "test:db": "bun test tests/db --timeout 30000",
    "test:api": "bun test tests/api --timeout 60000",
    "test:unit": "bun test tests/unit.test.js --timeout 30000",
    "test": "bun test tests/unit.test.js tests/db tests/api --timeout 60000",
    "start": "bun run serve",
    "serve": "tach.serve",
    "admin:create": "bun scripts/create-admin.mjs",
    "domain:migrate": "bun scripts/migrate-domain.mjs",
    "bundle": "bun ./scripts/bundle.mjs",
    "bundle:watch": "bun ./scripts/bundle.mjs --watch",
    "preview": "bun ./scripts/preview.mjs",
    "test:e2e": "bun run bundle && bun node_modules/.bin/playwright test",
    "test:e2e:ui": "bun run bundle && bun node_modules/.bin/playwright test --ui"
  },
  "dependencies": {
    "@delma/fylo": "^2.2.0",
    "@delma/tachyon": "^1.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/cli": "^4.2.2",
    "@types/mailparser": "^3.4.6",
    "@types/web-push": "^3.6.4",
    "bun-types": "^1.3.12",
    "tailwindcss": "^4.2.2"
  },
  "optionalDependencies": {
    "mailparser": "^3.9.8",
    "web-push": "^3.6.7"
  }
}
