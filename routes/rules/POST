#!/usr/bin/env bun
import { randomBytes } from 'node:crypto'
import { handle } from '../../src/shared/handler.ts'
import { r400, r401, r403 } from '../../src/shared/respond.ts'
import { verifyJwt, getJwtSecret } from '../../src/shared/auth.ts'
import { createDb } from '../../src/db/index.ts'
import { putRule } from '../../src/db/rules.ts'
import { validateInboxRuleActions } from '../../src/shared/rule-validation.ts'
import type { InboxRule } from '../../src/types.ts'

handle(async ({ body, context }) => {
  const claims = verifyJwt(context.bearer?.token ?? '', getJwtSecret())
  if (!claims) return r401('Authentication required')
  if (claims.role !== 'admin') return r403('Admin access required')

  const input = body as Partial<Omit<InboxRule, 'id'>>
  if (!input?.name) return r400('name required')
  if (!input.domain || !claims.domains.includes(input.domain)) return r403('Domain access denied')
  const actionError = validateInboxRuleActions(input.actions ?? [])
  if (actionError) return r400(actionError)

  const ruleId = randomBytes(16).toString('hex')
  const fylo = await createDb()
  await putRule(fylo, {
    id: ruleId,
    domain: input.domain,
    name: input.name,
    enabled: input.enabled ?? true,
    conditionMatch: input.conditionMatch ?? 'all',
    conditions: input.conditions ?? [],
    actions: input.actions ?? [],
  })

  return { id: ruleId }
})
