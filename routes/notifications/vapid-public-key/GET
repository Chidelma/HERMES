#!/usr/bin/env bun
import { handle } from '../../../src/shared/handler.ts'
import { getVapidPublicKey } from '../../../src/shared/push.ts'
import { isAuthError, requireClaims } from '../../../src/shared/notifications.ts'

handle(async ({ context }) => {
  const claims = requireClaims(context)
  if (isAuthError(claims)) return claims

  return { publicKey: await getVapidPublicKey() }
})
