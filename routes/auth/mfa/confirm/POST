#!/usr/bin/env bun
import { handle } from '../../../../src/shared/handler.ts'
import { r400, r401, r429 } from '../../../../src/shared/respond.ts'
import { signJwt, getJwtSecret } from '../../../../src/shared/auth.ts'
import { verifyTotp } from '../../../../src/shared/totp.ts'
import { createDb, Collections } from '../../../../src/db/index.ts'
import { findUserByEmail } from '../../../../src/db/users.ts'
import { findMfaSession, deleteMfaSession, listDevices } from '../../../../src/db/mfa.ts'
import { checkRateLimit } from '../../../../src/shared/rate-limit.ts'

const MAX_FAILED_ATTEMPTS = 5

handle(async ({ body, context }) => {
  const { mfaSessionId, code } = (body ?? {}) as Record<string, string>
  if (!mfaSessionId || !code) return r400('mfaSessionId and code required')

  const fylo = await createDb()
  const limit = await checkRateLimit(fylo, ['mfa-confirm', mfaSessionId, context.ipAddress], 12, 5 * 60 * 1000)
  if (!limit.allowed) return r429('Too many code attempts', limit.retryAfterSeconds)

  const [docId, session] = await findMfaSession(fylo, mfaSessionId)
  if (!session || !docId) return r401('Invalid or expired session')
  if (new Date(session.expiresAt) < new Date()) {
    await deleteMfaSession(fylo, docId)
    return r401('Session expired')
  }

  const devices = await listDevices(fylo, session.email)
  const valid = devices.some(d => verifyTotp(d.secret, code))
  if (!valid) {
    const failedAttempts = (session.failedAttempts ?? 0) + 1
    if (failedAttempts >= MAX_FAILED_ATTEMPTS) {
      await deleteMfaSession(fylo, docId)
    } else {
      await fylo.patchDoc(Collections.MFA_SESSIONS, { [docId]: { failedAttempts } })
    }
    return r401('Invalid code')
  }

  await deleteMfaSession(fylo, docId)

  const [, user] = await findUserByEmail(fylo, session.email)
  if (!user) return r401('Account not found')

  const token = signJwt({ email: user.email, domains: user.domains, role: user.role }, getJwtSecret())
  return { token, email: user.email, domains: user.domains, role: user.role }
})
