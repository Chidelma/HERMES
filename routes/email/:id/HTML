<script>
  function canUseApp() {
    return isBrowser && !!window._hermes?.auth?.isLoggedIn
  }

  function canShowLogin() {
    return isBrowser && !!window._hermes && !canUseApp()
  }
</script>

<logic :if="canUseApp()">
  <email-detail_ @compose="window._hermes?.compose($event.detail)" />
</logic>

<logic :if="canShowLogin()">
  <div class="login-screen">
    <login-form_ @login="window._hermes?.handleLogin($event.detail, location.pathname + location.search)" />
  </div>
</logic>
